// Superintendent101 Prisma Schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  username        String       @unique
  passwordHash    String?
  name            String?
  role            Role         @default(MEMBER)
  subscription    Subscription @default(FREE)
  trialEndsAt     DateTime?
  stripeCustomerId String?
  stripeSubId      String?
  // Procore OAuth (tokens encrypted at rest)
  procoreAccessToken  String?
  procoreRefreshToken String?
  procoreTokenExpiry  DateTime?
  procoreCompanyId    Int?
  betaTester      Boolean      @default(false)   // free for life — Stripe webhook skips these
  onboarded       Boolean      @default(false)
  defaultProjectId String?
  builderType     String?      // 'RESIDENTIAL' | 'COMMERCIAL'
  structureModel  String       @default("gpt-4o")  // AI model for structuring transcripts
  // Email sending (Option A — user's own SMTP)
  emailFromName   String?
  emailFromAddr   String?
  emailSmtpHost   String?
  emailSmtpPort   Int?
  emailSmtpSecure Boolean      @default(true)
  emailSmtpUser   String?
  emailSmtpPassEnc String?     // AES-256 encrypted
  // Push notifications
  pushToken              String?
  notifyDailyReminder    Boolean  @default(false)
  notifyReminderHour     Int      @default(17)    // hour in UTC (17 = 5pm UTC)
  // Scheduled reports
  weeklyReportScheduled  Boolean  @default(false)
  weeklyReportEmail      String?                  // override email; falls back to user.email
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  projects         Project[]
  apiUsageLogs     ApiUsageLog[]
  dailyLogs        DailyLog[]
  companyMemberships CompanyMember[]
}

enum Role {
  MEMBER
  MENTOR
  ADMIN
}

enum Subscription {
  FREE
  PRO
  DUST_LOGS
}

model Project {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  location       String?
  type           String?
  sqft           Int?
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?
  // Persistent header data — auto-fills every daily log
  address        String?
  permitNumber   String?
  webPortalId    String?
  portalType     String?       // e.g. "ePlans", "ProjectDox", "Accela"
  planNumber     String?       // residential plan set number
  elevation      String?       // e.g. "A", "B", "C"
  electricalSide String?       // e.g. "Left", "Right"
  createdAt      DateTime      @default(now())
  dailyLogs      DailyLog[]
  shares         ProjectShare[]
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
}


model ApiUsageLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service       String   // "whisper" | "gpt4o"
  action        String   // "transcribe" | "structure"
  inputTokens   Int?
  outputTokens  Int?
  fileSizeBytes Int?
  costUsd       Decimal  @db.Decimal(10, 6)
  projectName   String?
  createdAt     DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])
  date          DateTime @db.Date
  weather       String   @default("")
  crewCounts    Json     @default("{}")   // { "Framers": 4, "Electricians": 2 }
  crewPermits   Json     @default("{}")   // { "Electricians": "E-2024-123" } — commercial sub permit numbers per trade
  workPerformed String   @db.Text @default("")
  deliveries    String   @db.Text @default("")
  inspections   String   @db.Text @default("")
  issues        String   @db.Text @default("")
  safetyNotes   String   @db.Text @default("")
  photoUrls     String[] @default([])
  signatureUrl  String?
  transcript    String?  @db.Text        // raw voice transcript for reference
  equipment     String   @db.Text @default("")  // equipment on site → Procore equipment_logs
  accidents     String   @db.Text @default("")  // accidents / incidents → Procore accident_logs + Observations
  visitors      String   @db.Text @default("")  // visitors on site → Procore visitor_logs
  archived      Boolean  @default(false)
  address       String?                  // job site address for this log
  lotNumber     String?                  // residential lot number
  permitNumber  String?                  // permit number for this log
  rfi           String   @default("") @db.Text  // RFIs logged this day
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Company Groups (white-label client management) ────────────────────────────

model Company {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique   // used in URLs / API references
  logoUrl          String?
  brandColor       String          @default("#2563eb")
  contactEmail     String?
  seats            Int             @default(10)   // max members allowed
  active           Boolean         @default(true)
  grantsBetaTester Boolean         @default(false) // all members get free-for-life
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  members      CompanyMember[]
}

model CompanyMember {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        CompanyRole @default(MEMBER)
  joinedAt    DateTime    @default(now())

  @@unique([companyId, userId])
}

enum CompanyRole {
  OWNER
  MEMBER
}

// ─── Bug / Feedback Reports ────────────────────────────────────────────────────

model ProcoreProjectLink {
  id               String   @id @default(cuid())
  userId           String
  projectId        String
  procoreProjectId Int
  procoreCompanyId Int
  createdAt        DateTime @default(now())

  @@unique([userId, projectId])
}

// ─── Project Share Links (subcontractor read-only access) ─────────────────────

model ProjectShare {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  token     String    @unique @default(cuid())
  label     String?   // e.g. "Shared with ABC Electrical"
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  viewCount Int       @default(0)
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String?
  userEmail   String?
  category    String   @default("bug")   // "bug" | "feedback" | "feature"
  description String   @db.Text
  deviceInfo  String?  @db.Text          // JSON string: platform, browser, OS, appVersion
  status      String   @default("open")  // "open" | "in_progress" | "resolved" | "wont_fix"
  createdAt   DateTime @default(now())
}
